{
 // Config of Szonszczyk - All in Weapon: Unslotted


 "ModEnabled": true, // true/false - default: true
 // Changing this value to false will disable the mod

 // Use any mod in any weapon slot
 "FckWeapons": true, // true/false - default: true
 // Use any mod in any mod slot
 "FckMods": true, // true/false - default: true
 // Use any magazine with any weapon
 "FckMagazines": true, // true/false - default: true
 // Use any bullet with any magazine and weapon
 "FckBullets": true, // true/false - default: true

 "FckALL": false, // true/false - default: false

 // Removes Conflicting Items filter from mods
 "RemoveConflictingItems": true, // true/false - default: true

 // Enables different way to "unslot" slots, can help when the game (client) is not loading
 // Can have some strange interactions with different mods
 "Experimental": true // true/false - default: false
}